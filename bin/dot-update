#!/usr/bin/env bash
# Description: Update all the things

set -Eeuo pipefail

# Derive DOTFILES from script location when unset (first-run / isolated shells)
: "${DOTFILES:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." &>/dev/null && pwd -P)}"
export DOTFILES

# source helpers
source "$DOTFILES/bin/lib/common.sh"
command_name=$(basename "${BASH_SOURCE[0]}")

readonly SPINNER_STYLE=11

TMPFILES=()
cleanup_tmpfiles() {
  [[ ${#TMPFILES[@]} -gt 0 ]] && rm -f "${TMPFILES[@]}"
}
trap cleanup_tmpfiles EXIT

mktemp_tracked() {
  local f
  f=$(mktemp "$@")
  TMPFILES+=("$f")
  printf '%s' "$f"
}

usage() {
  cat <<EOF
  $(fmt_key "Usage:") $(fmt_key "$command_name") $(fmt_value "[options] <command>")

  Update all the things. This script can be used to update Neovim plugins,
  update Homebrew packages, and more.

Options:
    -h, --help           Show this help message
    nvim, vim            Update Neovim plugins
    homebrew, brew       Update Homebrew packages
    dotfiles             Update dotfiles
    zsh                  Update Zsh plugins
    claude               Install or update Claude Code (native installer)
    all                  Update everything
EOF
}

update_homebrew() {
  fmt_title_underline "Updating Homebrew packages"

  if ! command -v brew >/dev/null 2>&1; then
    log_warning "brew not found; skipping"
    return 0
  fi

  # Homebrew on macOS is owned by a single admin user; other local users
  # (e.g. isolated workspace accounts) can read it but not brew update/upgrade.
  # Detect and skip instead of exploding with 'Cellar is not writable'.
  local cellar
  cellar="$(brew --cellar 2>/dev/null)"
  if [[ -n "$cellar" && ! -w "$cellar" ]]; then
    log_warning "Homebrew Cellar is not writable by $(whoami); skipping"
    log_info "  run 'bin/dot update brew' from the admin user who installed Homebrew"
    return 0
  fi

  local log_file
  log_file=$(mktemp_tracked)

  run_with_spinner "brew update > '$log_file' 2>&1 && brew upgrade >> '$log_file' 2>&1" $SPINNER_STYLE "Updating Homebrew"

  if grep -q "Error\|fatal\|Failed" "$log_file"; then
    log_error "Error occurred during update:"
    cat "$log_file"
    return 1
  fi

  grep -A1 "=>" "$log_file" | grep -v "^--$" || log_info "No updates found"
  echo -e
}

update_nvim_plugins() {
  fmt_title_underline "Updating Neovim plugins"

  if ! command -v nvim >/dev/null 2>&1; then
    log_warning "nvim not installed; skipping plugin update."
    log_info "Run 'dot homebrew bundle' to install Brewfile packages (includes neovim)."
    return 0
  fi

  local log_file
  log_file=$(mktemp_tracked)

  run_with_spinner "nvim --headless '+Lazy! sync' +qa > '$log_file' 2>&1" $SPINNER_STYLE "Updating Neovim plugins"

  if grep -q "^Error\|^ERROR\|Could not\|not installed" "$log_file"; then
    log_error "Error occurred during update:"
    echo "───────── nvim log ─────────"
    cat "$log_file"
    echo "────────────────────────────"
    return 1
  fi

  grep -i "updated\|installed\|removed" "$log_file" || log_info "No updates found"
  echo -e
}

update_dotfiles() {
  fmt_title_underline "Updating dotfiles"

  current_branch="$(git -C "$DOTFILES" symbolic-ref --short HEAD)"
  if [ "$current_branch" != "main" ]; then
    log_warning "Not on main branch (current: $current_branch)"
    return 1
  fi

  local log_file
  log_file=$(mktemp_tracked)

  run_with_spinner "git -C '$DOTFILES' fetch --quiet origin main > '$log_file' 2>&1" $SPINNER_STYLE "Checking for dotfiles updates"

  # Use merge-base to distinguish up-to-date / ahead / behind / diverged
  # so we don't print "Updates available:" when local is ahead of origin.
  local_rev=$(git -C "$DOTFILES" rev-parse HEAD)
  remote_rev=$(git -C "$DOTFILES" rev-parse "@{u}" 2>/dev/null || true)
  if [ -z "$remote_rev" ]; then
    log_warning "No upstream configured for current branch; skipping"
    return 0
  fi
  base=$(git -C "$DOTFILES" merge-base HEAD "@{u}")

  if [ "$local_rev" = "$remote_rev" ]; then
    log_info "Dotfiles are up to date"
    return 0
  elif [ "$base" = "$remote_rev" ]; then
    local ahead
    ahead=$(git -C "$DOTFILES" rev-list --count "@{u}..HEAD")
    log_info "Local is ahead of origin by $ahead commit(s); nothing to pull"
    return 0
  elif [ "$base" != "$local_rev" ]; then
    log_warning "Local and origin have diverged; resolve manually"
    return 1
  fi

  echo "Updates available:"
  git -C "$DOTFILES" --no-pager log --oneline --graph --decorate --color=always HEAD.."@{u}"
  if run_with_spinner "git -C '$DOTFILES' pull --ff-only origin main > '$log_file' 2>&1" $SPINNER_STYLE "Updating dotfiles"; then
    log_info "Dotfiles updated successfully"
  else
    log_error "Failed to update dotfiles"
    cat "$log_file"
    return 1
  fi
}

update_claude_code() {
  fmt_title_underline "Updating Claude Code"

  if command -v claude >/dev/null 2>&1; then
    local log_file
    log_file=$(mktemp_tracked)

    if run_with_spinner "claude update > '$log_file' 2>&1" $SPINNER_STYLE "Updating Claude Code"; then
      tail -3 "$log_file" | sed '/^\s*$/d'
    else
      log_error "claude update failed:"
      cat "$log_file"
      return 1
    fi
  else
    log_info "Claude Code not installed; running Anthropic's native installer"
    local installer
    installer=$(mktemp_tracked -t claude-install.XXXXXX)

    if ! curl -fsSL -o "$installer" https://claude.ai/install.sh; then
      log_error "Failed to download installer from https://claude.ai/install.sh"
      return 1
    fi

    if ! head -1 "$installer" | grep -q '^#!/bin/bash'; then
      log_error "Downloaded installer is not a bash script; aborting"
      return 1
    fi

    if bash "$installer"; then
      log_success "Claude Code installed"
    else
      log_error "Installer failed"
      return 1
    fi
  fi
  echo -e
}

update_zsh_plugins() {
  fmt_title_underline "Updating ZSH plugins..."
  echo -e

  local cwd="$(pwd)"
  while IFS=: read -r name path; do
    cd "$path" || { log_error "cannot enter $path"; return 1; }

    local before=$(git rev-parse HEAD)

    run_with_spinner 'git pull --quiet --recurse-submodules' $SPINNER_STYLE "Updating $name..."

    local after=$(git rev-parse HEAD)
    if [[ $before != $after ]]; then
      local commit_count=$(git rev-list --count "$before".."$after")
      local commit_msg=$(git log -1 --pretty=format:"%s")
      log_success "$name updated ($commit_count new commit(s))"
      fmt_value "  → $commit_msg"
    else
      log_info "$name already up to date"
    fi

    cd "$cwd" || { log_error "cannot return to $cwd"; return 1; }
  done < <(zsh -ic 'for k in ${(k)plugins}; do echo "$k:$plugins[$k]"; done')

  echo -e
  log_success "ZSH Plugin updates completed."
}

main() {
  local subcmd=""

  if [ $# -lt 1 ]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    *)
      subcmd="$1"
      shift
      ;;
    esac
  done

  case "$subcmd" in
  nvim | vim)
    update_nvim_plugins
    ;;
  homebrew | brew)
    update_homebrew
    ;;
  dotfiles)
    update_dotfiles
    ;;
  zsh)
    update_zsh_plugins
    ;;
  claude | claude-code)
    update_claude_code
    ;;
  all)
    local failures=()
    update_nvim_plugins || failures+=("nvim")
    update_homebrew     || failures+=("homebrew")
    update_zsh_plugins  || failures+=("zsh")
    update_dotfiles     || failures+=("dotfiles")
    update_claude_code  || failures+=("claude")
    if [ "${#failures[@]}" -gt 0 ]; then
      log_warning "Some updates failed: ${failures[*]}"
      exit 1
    fi
    ;;
  *)
    log_error "Unknown $command_name command: $subcmd"
    echo -e
    usage
    exit 1
    ;;
  esac
}

main "$@"
