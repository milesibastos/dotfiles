#!/usr/bin/env bash
# Description: Setup shell configuration

set -Eeuo pipefail

# Derive DOTFILES from script location when unset (first-run / isolated shells)
: "${DOTFILES:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." &>/dev/null && pwd -P)}"
export DOTFILES

# source helpers
source "$DOTFILES/bin/lib/common.sh"
command_name=$(basename "${BASH_SOURCE[0]}")

usage() {
  cat <<EOF
  $(fmt_key "Usage:") $(fmt_key "$command_name") $(fmt_value "[options] <command>")

  Setup shell configuration. This can be used to set the default shell, install terminfo, etc.

  - default shell: fish. Pass 'zsh' to change to zsh instead.
  - terminfo: Terminfo files are installed for tmux, neovim, and ghostty. They help us to
    have italic text and other features, and ensure proper terminal behavior over SSH.


Options:
    -h, --help            Show this help message
    change [fish|zsh]     change the login shell (default: fish)
    terminfo              Add terminfo files
EOF
}

cmd_change() {
  local shell_name="${1:-fish}"
  case "$shell_name" in
  fish | zsh) ;;
  *)
    log_error "unsupported shell: $shell_name (expected fish or zsh)"
    exit 1
    ;;
  esac

  fmt_title_underline "Configuring shell ($shell_name)"

  local shell_path
  if [[ -n "$(command -v brew)" ]] && [[ -x "$(brew --prefix)/bin/$shell_name" ]]; then
    shell_path="$(brew --prefix)/bin/$shell_name"
  else
    shell_path="$(command -v "$shell_name" || true)"
  fi

  if [[ -z "$shell_path" ]]; then
    log_error "$shell_name not found on PATH — install it first (e.g. 'brew install $shell_name')"
    exit 1
  fi

  if ! grep -qxF "$shell_path" /etc/shells; then
    log_info "adding $shell_path to /etc/shells"
    echo "$shell_path" | sudo tee -a /etc/shells >/dev/null
  fi

  if [[ "$SHELL" != "$shell_path" ]]; then
    chsh -s "$shell_path"
    log_success "default shell changed to $shell_path"
  else
    log_info "default shell is already $shell_path"
  fi
}

cmd_terminfo() {
  fmt_title_underline "Configuring terminfo"

  log_info "adding tmux.terminfo"
  tic -x "$DOTFILES/resources/tmux.terminfo"

  log_info "adding xterm-256color-italic.terminfo"
  tic -x "$DOTFILES/resources/xterm-256color-italic.terminfo"

  log_info "adding xterm-ghostty.terminfo"
  tic -x "$DOTFILES/resources/xterm-ghostty.terminfo"

  log_success "terminfo files added."
}

main() {
  if [ $# -lt 1 ]; then
    usage
    exit 0
  fi

  case "$1" in
  -h | --help)
    usage
    exit 0
    ;;
  change)
    shift
    cmd_change "$@"
    ;;
  terminfo)
    cmd_terminfo
    ;;
  *)
    log_error "Unknown $command_name command: $1"
    echo -e
    usage
    exit 1
    ;;
  esac
}

main "$@"
